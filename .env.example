# OpenClaw (render with: python3 scripts/render_openclaw_config.py)
OPENCLAW_CONFIG_PATH=./openclaw/openclaw.json
OPENCLAW_STATE_DIR=./.openclaw-state
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PORT=19809
OPENCLAW_GATEWAY_BIND=loopback
OPENCLAW_WORKSPACE_DIR=.
OPENCLAW_ROLE=dev

# Telegram (BotFather) — long polling locally; set webhook* for K8s/Ingress
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=
TELEGRAM_DM_POLICY=pairing
TELEGRAM_GROUP_POLICY=allowlist
TELEGRAM_ENABLED=true
# TELEGRAM_WEBHOOK_URL=https://bots.example.com/telegram/dev
# TELEGRAM_WEBHOOK_SECRET=
# TELEGRAM_WEBHOOK_PATH=/telegram/dev
# TELEGRAM_WEBHOOK_HOST=0.0.0.0
# TELEGRAM_WEBHOOK_PORT=8787

# Ollama (local dev default per report)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL_ID=llama3.2
OLLAMA_MODEL_NAME=Llama 3.2
OLLAMA_CONTEXT_WINDOW=8192
OLLAMA_MAX_TOKENS=4096

# AI IR core (docker compose services)
QDRANT_URL=http://127.0.0.1:6333
REDIS_URL=redis://127.0.0.1:6379/0
AIIR_PROJECT_ID=default

# Elasticsearch + OpenAI (baseline RAG)
ES_URL=http://localhost:9200
ES_PASSWORD=
# ES_CA_CERTS=./elasticsearch-8.8.0/config/certs/http_ca.crt
OPENAI_API_KEY=
DATA_DIR=./data
