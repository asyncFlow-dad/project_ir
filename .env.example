# OpenClaw — render config: python3 scripts/render_openclaw_config.py
OPENCLAW_CONFIG_PATH=./openclaw/openclaw.json
OPENCLAW_STATE_DIR=./.openclaw-state
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PORT=19809
OPENCLAW_GATEWAY_BIND=loopback
OPENCLAW_WORKSPACE_DIR=.
OPENCLAW_ROLE=dev

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_ID=claude-sonnet-4-5
ANTHROPIC_MODEL_NAME=Claude Sonnet 4.5

# Telegram (BotFather) — long polling locally
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=
TELEGRAM_DM_POLICY=pairing
TELEGRAM_GROUP_POLICY=allowlist
TELEGRAM_ENABLED=true

# AI IR core
QDRANT_URL=http://127.0.0.1:6333
REDIS_URL=redis://127.0.0.1:6379/0
AIIR_PROJECT_ID=default
DATA_DIR=./data
